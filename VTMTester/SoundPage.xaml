<Page
    x:Class="VTMTester.SoundPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:VTMTester"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
    Title="SoundPage"
    d:Height="1000"
    d:Width="1800"
    mc:Ignorable="d">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/CSS/FlatStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Center cell content: stretch the row so HorizontalAlignment=Center works per cell -->
            <Style x:Key="StepRowStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            </Style>
            <!-- Centered, NON-resizable column headers (template has no gripper thumb) -->
            <Style x:Key="CenterHeader" TargetType="GridViewColumnHeader">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GridViewColumnHeader">
                            <Border  BorderThickness="0,0,1,1" Padding="4,4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Rounded button -->
            <Style x:Key="RoundBtn" TargetType="Button">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Rounded toggle (icon buttons: Flag, Eye) -->
            <Style x:Key="RoundToggle" TargetType="ToggleButton">
                <Setter Property="Background" Value="#CFD8DC"/>
                <Setter Property="Foreground" Value="#37474F"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#1976D2"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Segmented radio button for the 3-mode selector -->
            <Style x:Key="ModeSeg" TargetType="RadioButton">
                <Setter Property="Foreground" Value="#37474F"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#1976D2"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#1976D2"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: header device + capture control + step selector. White background (blue removed at user request);
             text/icon colours darkened to stay readable. -->
        <Border Grid.Row="0" Background="White" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="SOUND PROCESSING" FontSize="16" FontWeight="Bold"
                           Foreground="Black" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <fa:IconBlock Grid.Column="1" Icon="Microphone" Foreground="#37474F" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Grid.Column="2" x:Name="txtDevice" Text="(default microphone)" Foreground="#333333"
                           VerticalAlignment="Center" MinWidth="160" Margin="0,0,10,0"/>

                <!-- START/STOP right after the microphone name (rounded) -->
                <ToggleButton Grid.Column="3" x:Name="btnCaptureToggle" Width="96" Height="30" Margin="0,0,20,0"
                              Foreground="White" FontWeight="Bold" BorderThickness="0"
                              Background="#4CAF50" Checked="btnCaptureToggle_Changed" Unchecked="btnCaptureToggle_Changed"
                              ToolTip="Toggle capture (Start / Stop)">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="4,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock x:Name="iconCaptureToggle" Icon="Play" Margin="0,0,4,0"/>
                        <TextBlock x:Name="txtCaptureToggle" Text="START"/>
                    </StackPanel>
                </ToggleButton>


                <!-- Right block: TWO rows - top = MODEL + Open/Save/Save As, bottom = EDIT/CHECK/DIAG. -->
                <StackPanel Grid.Column="7" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Styled identically to the Vision/Model page toolbar: "MODEL: <name>" + fixed-width
                         Open Model / Save / Save As buttons (amber icon + black label). Keeps SoundPage's own button
                         x:Names + Click handlers + txtModelName. -->
                        <Label Margin="5,0,0,0" Padding="0" VerticalAlignment="Center"
                           Content="MODEL: " FontSize="15" FontStyle="Italic" FontWeight="DemiBold" Foreground="Black" />
                        <TextBlock x:Name="txtModelName" Margin="0,0,5,0" Padding="0" VerticalAlignment="Center"
                               FontSize="16" FontStyle="Italic" FontWeight="DemiBold" Foreground="Black"
                               Text="(no model)" TextTrimming="CharacterEllipsis" MaxWidth="220" />
                        <Button x:Name="btnOpenModel" Width="120" Height="30" Margin="0,5" Padding="5"
                            HorizontalContentAlignment="Center" Background="{x:Null}" BorderThickness="0"
                            Cursor="Hand" FontSize="14" Foreground="#FF109322" Click="btnOpenModel_Click"
                            ToolTip="Open a model file" Template="{DynamicResource ButtonControlNonHoverEffect}">
                            <Grid HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <fa:IconImage Margin="2" Icon="FolderOpen" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#ffa000"/>
                                <Label Grid.Column="1" Margin="5,0,0,0" Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Content="Open Model" FontSize="12" FontStretch="UltraExpanded" FontWeight="Bold" Foreground="Black" />
                            </Grid>
                        </Button>
                        <Button x:Name="btnSaveModel" Width="80" Height="30" Margin="0,5" Padding="5"
                            HorizontalContentAlignment="Center" Background="{x:Null}" BorderThickness="0"
                            Cursor="Hand" FontSize="14" Foreground="#FF109322" Click="btnSaveModel_Click"
                            ToolTip="Save the model (Ctrl+S)" Template="{DynamicResource ButtonControlNonHoverEffect}">
                            <Grid HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <fa:IconImage Margin="2" Icon="Save" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#ffa000"/>
                                <Label Grid.Column="1" Margin="5,0,0,0" Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Content="Save" FontSize="12" FontStretch="UltraExpanded" FontWeight="Bold" Foreground="Black" />
                            </Grid>
                        </Button>
                        <Button x:Name="btnSaveAsModel" Width="80" Height="30" Margin="0,5" Padding="5"
                            HorizontalContentAlignment="Center" Background="{x:Null}" BorderThickness="0"
                            Cursor="Hand" FontSize="14" Foreground="#FF109322" Click="btnSaveAsModel_Click"
                            ToolTip="Save the model as a new file" Template="{DynamicResource ButtonControlNonHoverEffect}">
                            <Grid HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <fa:IconImage Margin="2" Icon="Save" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#ffa000"/>
                                <fa:IconImage Icon="CirclePlus" VerticalAlignment="Top" HorizontalAlignment="Left" Foreground="#ffa000" Margin="16,0,0,0" Height="7" Width="7" Grid.ColumnSpan="2" />
                                <Label Grid.Column="1" Margin="5,0,0,0" Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Content="Save As" FontSize="12" FontStretch="UltraExpanded" FontWeight="Bold" Foreground="Black" />
                            </Grid>
                        </Button>
                    </StackPanel>
                    <!-- Bottom row: EDIT / CHECK / DIAG mode toggle, right-aligned under the Open/Save/Save As row. -->
                   
                </StackPanel>
            </Grid>
        </Border>


        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10 0" >
                <Border BorderBrush="#546E7A" BorderThickness="1" CornerRadius="4" Height="30">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="rbModeEdit" GroupName="SndPageMode" IsChecked="True"
             Checked="Mode_Changed" Style="{StaticResource ModeSeg}"
             ToolTip="EDIT: edit ROIs / parameters of the selected step">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="PenToSquare" Margin="0,0,4,0"/>
                                <TextBlock Text="EDIT"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="rbModeCheck" GroupName="SndPageMode"
             Checked="Mode_Changed" Style="{StaticResource ModeSeg}"
             ToolTip="CHECK: read-only, manually press START for realtime scoring with the selected step">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="MagnifyingGlassChart" Margin="0,0,4,0"/>
                                <TextBlock Text="CHECK"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="rbModeDiag" GroupName="SndPageMode"
             Checked="Mode_Changed" Style="{StaticResource ModeSeg}"
             ToolTip="DIAGNOSTIC: monitor auto/manual test - push graph + ROI + pass/fail over for debugging">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconBlock Icon="Bug" Margin="0,0,4,0"/>
                                <TextBlock Text="DIAG"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Border>
            </StackPanel>
            <StackPanel>

                <!-- Row 1: selected ROI threshold (spectrogram only) -->
                <Border Grid.Row="1" Background="White" Padding="10,6">
                    <StackPanel Orientation="Horizontal">
                        <!-- Selected ROI: Min NCC threshold via a 0-100% slider -->
                        <fa:IconBlock Icon="ObjectGroup" Foreground="#37474F" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Sel ROI:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="txtSelRoi" Text="(none)" VerticalAlignment="Center" MinWidth="100" FontFamily="Consolas" Margin="0,0,10,0"/>
                        <TextBlock Text="Min NCC:" VerticalAlignment="Center" Margin="0,0,6,0"
                  ToolTip="NCC threshold for Template matching (0-100%). ROI passes when score >= Min."/>
                        <Slider x:Name="sldRoiMin" Width="180" Minimum="0" Maximum="100" Value="30"
               VerticalAlignment="Center" TickFrequency="5" IsSnapToTickEnabled="False"
               ValueChanged="RoiMinSlider_ValueChanged"/>
                        <TextBlock x:Name="txtRoiMinPct" Text="30%" VerticalAlignment="Center"
                  MinWidth="42" FontFamily="Consolas" Margin="8,0,20,0"/>

                        <!-- Live NCC of the selected ROI (updated each frame while capturing) -->
                        <TextBlock Text="NCC:" VerticalAlignment="Center" Margin="0,0,4,0"
                  ToolTip="Live NCC score of the selected ROI vs its captured template"/>
                        <Border x:Name="ncBorder" Background="#CFD8DC" CornerRadius="3" Padding="6,1" VerticalAlignment="Center">
                            <TextBlock x:Name="txtRoiScore" Text="--" FontFamily="Consolas" FontWeight="Bold"
                      Foreground="#263238" MinWidth="42"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Row 2: FFT/dB/Color/Metric params + edit-mode toolbar (like ZEROC paramPanel) -->
                <Border Grid.Row="2" Background="White" Padding="10,6">
                    <StackPanel Orientation="Horizontal">
                        <fa:IconBlock Icon="ChartLine" Foreground="#37474F" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="FFT:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox x:Name="cboFft" Width="70" SelectedIndex="1" VerticalAlignment="Center" Margin="0,0,10,0"
                 SelectionChanged="Param_Changed">
                            <ComboBoxItem>1024</ComboBoxItem>
                            <ComboBoxItem>2048</ComboBoxItem>
                            <ComboBoxItem>4096</ComboBoxItem>
                            <ComboBoxItem>8192</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Text="Max Hz:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox x:Name="txtMaxHz" Width="70" Text="8000" VerticalAlignment="Center" Margin="0,0,10,0"
                LostFocus="Param_Changed"/>

                        <TextBlock Text="dB:" VerticalAlignment="Center" Margin="0,0,4,0"
                  ToolTip="Spectrogram contrast range (floor - top)"/>
                        <TextBox x:Name="txtDbFloor" Width="45" Text="-90" VerticalAlignment="Center" Margin="0,0,3,0" ToolTip="dB floor (mapped to darkest)" LostFocus="Param_Changed"/>
                        <TextBlock Text="~" VerticalAlignment="Center" Margin="0,0,3,0"/>
                        <TextBox x:Name="txtDbTop"   Width="45" Text="-10" VerticalAlignment="Center" Margin="0,0,10,0" ToolTip="dB top (mapped to brightest)" LostFocus="Param_Changed"/>

                        <TextBlock Text="Color:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox x:Name="cboColor" Width="90" SelectedIndex="0" VerticalAlignment="Center" Margin="0,0,15,0"
                 SelectionChanged="cboColor_SelectionChanged"
                 ToolTip="Colormap - Hot/Viridis/Magma/Turbo/Jet/Grayscale">
                            <ComboBoxItem>Hot</ComboBoxItem>
                            <ComboBoxItem>Viridis</ComboBoxItem>
                            <ComboBoxItem>Magma</ComboBoxItem>
                            <ComboBoxItem>Turbo</ComboBoxItem>
                            <ComboBoxItem>Jet</ComboBoxItem>
                            <ComboBoxItem>Grayscale</ComboBoxItem>
                        </ComboBox>

                        <Border Width="1" Background="#B0BEC5" Margin="6,2,6,2"/>

                        <!-- EDIT mode: Revert + Capture (ROI always editable, no Pen needed). CHECK mode: Flag + Eye. -->
                        <Button x:Name="btnRevertRoi" Height="28" Width="34" VerticalAlignment="Center"
               Background="#607D8B" Style="{StaticResource RoundBtn}" Click="btnRevertRoi_Click"
               ToolTip="Revert ROIs to the step's saved set (undo unsaved changes) - EDIT mode">
                            <fa:IconBlock Icon="RotateLeft" FontSize="12"/>
                        </Button>
                        <Button x:Name="btnCapture" Height="28" Width="34" VerticalAlignment="Center" Margin="6,0,0,0"
               Background="#607D8B" Style="{StaticResource RoundBtn}" Click="btnCapture_Click"
               ToolTip="Capture template for SELECTED ROI - EDIT mode">
                            <fa:IconBlock Icon="Camera" FontSize="12"/>
                        </Button>

                        <ToggleButton x:Name="chkStopOnPass" Height="28" Width="34" VerticalAlignment="Center" Margin="6,0,0,0"
                     Style="{StaticResource RoundToggle}"
                     Checked="chkStopOnPass_Changed" Unchecked="chkStopOnPass_Changed"
                     ToolTip="Auto-stop capture when every ROI passes - CHECK mode">
                            <fa:IconBlock Icon="FlagCheckered" FontSize="12"/>
                        </ToggleButton>
                        <ToggleButton x:Name="chkRoiVis" Height="28" Width="34" VerticalAlignment="Center" Margin="6,0,0,0" IsChecked="True"
                     Style="{StaticResource RoundToggle}"
                     Checked="chkRoiVis_Changed" Unchecked="chkRoiVis_Changed"
                     ToolTip="Show / hide ROI overlays - CHECK mode">
                            <fa:IconBlock x:Name="iconRoiVis" Icon="Eye" FontSize="12"/>
                        </ToggleButton>

                        <Border Width="1" Background="#B0BEC5" Margin="6,2,6,2"/>

                        <Button x:Name="btnHelp" Height="28" Width="34" VerticalAlignment="Center"
               Background="#607D8B" Style="{StaticResource RoundBtn}" Click="btnHelp_Click" ToolTip="Help (F12)">
                            <fa:IconBlock Icon="CircleQuestion" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </Border>

            </StackPanel>

        </Grid>
 
        <!-- Row 3: spectrogram canvas + help overlay (Stretch=Fill like ZEROC) -->
        <Border Grid.Row="3" Background="Black" Margin="10">
            <Grid>
                <!-- LIVE layer (EDIT / CHECK) -->
                <Grid x:Name="liveLayer">
                    <Image  x:Name="specImage" Stretch="Fill" RenderOptions.BitmapScalingMode="Linear"/>
                    <Canvas x:Name="roiCanvas" Background="Transparent" IsHitTestVisible="False"/>
                </Grid>

                <!-- DIAG layer (separate canvas, only shown when a test pushes a snapshot) -->
                <Grid x:Name="diagLayer" Visibility="Collapsed">
                    <Image  x:Name="specImageDiag" Stretch="Fill" RenderOptions.BitmapScalingMode="Linear"/>
                    <Canvas x:Name="roiCanvasDiag" Background="Transparent" IsHitTestVisible="False"/>
                </Grid>

                <Border x:Name="helpOverlay" Visibility="Collapsed" Background="#E6141B22" CornerRadius="6" Padding="18"
                        HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14" MaxWidth="600">
                    <StackPanel>
                        <TextBlock Text="SOUND PROCESSING - quick help" FontWeight="Bold" FontSize="12" Foreground="White" Margin="0,0,0,8"/>
                        <TextBlock Foreground="#D8DEE6" FontSize="10.5" TextWrapping="Wrap" LineHeight="17">
                            <Run Text="- ROIs are GLOBAL on the model (not tied to any step). 3 modes: EDIT = edit the global ROIs/parameters + START to view live; CHECK = START realtime scoring, left-click ROIs to designate them; DIAG = monitor an auto/manual test (shows the SND step name)."/><LineBreak/>
                            <Run Text="- EDIT: double-click empty = create box; double-click box = clone; drag inside = move; drag corner/edge = resize; right-click or Delete = delete."/><LineBreak/>
                            <Run Text="- CHECK: press START for realtime NCC scoring. Left-click a ROI to designate it (checkmark, gold border); the stop-on-pass flag freezes capture once all designated ROIs match. No designation = wait for all ROIs."/><LineBreak/>
                            <Run Text="- Eye toggle: show / hide the ROI overlay when not in EDIT mode."/><LineBreak/>
                            <Run Text="- Flag (StopOnPass, CHECK mode only): auto-stop capture when the designated ROIs pass; turning it off clears the designations."/><LineBreak/>
                            <Run Text="- Color: select colormap (Hot / Viridis / Magma / Turbo / Jet / Grayscale)."/><LineBreak/>
                            <Run Text="- Metric: Template = NCC with a 48x64 patch. Capture template: snapshot the patch from the selected ROI (EDIT mode)."/><LineBreak/>
                            <Run Text="- Revert: restore the global ROIs to the last saved state (undo)."/><LineBreak/>
                            <Run Text="- ROIs and templates are saved WITH the model on Save."/>
                        </TextBlock>
                        <TextBlock Text="Press F12 or ? to close" Foreground="#8A94A0" FontSize="9.5" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Row 4: single status bar. Shows the SND step under test inline (purple) only in DIAG mode. -->
        <Border Grid.Row="4" x:Name="pnlStatus" Background="#303030" Padding="10,4">
            <StackPanel Orientation="Horizontal">
                <fa:IconBlock Icon="CircleInfo" Foreground="#B0BEC5" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="txtInfo"   Text="Idle" Foreground="#B0BEC5" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <!-- DIAG: which SND step the running test is mirroring (inline, DIAG mode only) -->
                <StackPanel x:Name="pnlDiagStep" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed" Margin="0,0,24,0">
                    <fa:IconBlock Icon="Wrench" Foreground="#CE93D8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="SND step under test:" Foreground="#CE93D8" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="txtDiagStep" Text="(waiting for an SND test step...)" Foreground="White"
                               FontFamily="Consolas" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="txtCursor" Text="" Foreground="#B0BEC5" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
