<Page
    x:Class="VTMTester.SettingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctr="clr-namespace:VTMControls;assembly=VTMControls"
    xmlns:dc="clr-namespace:VTMControls.DeviceControl;assembly=VTMControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
    xmlns:local="clr-namespace:VTMTester"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:xc="clr-namespace:VTMControls.CustomControls;assembly=VTMControls"
    Title="SettingPage"
    mc:Ignorable="d">
    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/CSS/FlatStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>
    <Grid Background="#f6f6f6">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <TabControl
            Margin="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="#11ffffff"
            BorderThickness="0"
            FontWeight="Bold"
            TabStripPlacement="Left">
            <TabItem
                Width="200"
                Height="40"
                Padding="0"
                Header="Operations"
                Style="{StaticResource FlatTabControlLeft}">
                <Grid
                    Width="500"
                    Margin="-2,0,0,0"
                    HorizontalAlignment="Left"
                    Background="#003a71">
                    <StackPanel>
                        <GroupBox
                            Margin="10"
                            BorderThickness="0"
                            Header="Auto Test setting">
                            <Grid Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>

                                <CheckBox
                                    x:Name="cbNoTextPressUp"
                                    Grid.ColumnSpan="2"
                                    Content="When the situation no test, auto press up" />
                                <Label
                                    Grid.Row="1"
                                    HorizontalContentAlignment="Right"
                                    Content="Start delay time"
                                    Foreground="LightGray" />
                                <xc:IntegerUpDown
                                    x:Name="nudStartDelay"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Width="80"
                                    Margin="2"
                                    HorizontalAlignment="Right"
                                    Maximum="10000"
                                    Minimum="100"
                                    Value="500" />
                                <Label
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    HorizontalContentAlignment="Left"
                                    Content="ms"
                                    Foreground="LightGray" />

                                <Label
                                    Grid.Row="2"
                                    HorizontalContentAlignment="Right"
                                    Content="Test end press up time"
                                    Foreground="LightGray" />
                                <xc:IntegerUpDown
                                    x:Name="nudPressUpTime"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Width="80"
                                    Margin="2"
                                    HorizontalAlignment="Right"
                                    Maximum="10000"
                                    Minimum="100"
                                    Value="500" />
                                <Label
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    HorizontalContentAlignment="Left"
                                    Content="ms"
                                    Foreground="LightGray" />
                            </Grid>
                        </GroupBox>
                        <GroupBox
                            Margin="10,0,10,10"
                            BorderThickness="0"
                            Header="When fail occures, operations">
                            <Grid Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>

                                <RadioButton
                                    x:Name="rbFailTestContinue"
                                    HorizontalAlignment="Center"
                                    Content="Test continue"
                                    Foreground="LightGray" />
                                <RadioButton
                                    x:Name="rbFailTestStopAll"
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    Content="Stop all"
                                    Foreground="LightGray" />
                                <RadioButton
                                    x:Name="rbFailTestStopPCB"
                                    Grid.Column="2"
                                    HorizontalAlignment="Center"
                                    Content="Stop fail PCB"
                                    Foreground="LightGray" />

                                <CheckBox
                                    x:Name="cbResistanceFailStop"
                                    Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Content="Resistance fail, force stop all" />
                                <Label
                                    Grid.Row="2"
                                    Grid.ColumnSpan="2"
                                    HorizontalAlignment="Left"
                                    HorizontalContentAlignment="Right"
                                    Content="Error step jump use count"
                                    Foreground="LightGray" />
                                <xc:IntegerUpDown
                                    x:Name="nudErrorJumpCount"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Width="80"
                                    Margin="2"
                                    HorizontalAlignment="Right"
                                    Maximum="10"
                                    Minimum="1"
                                    Value="1" />
                                <Label
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    HorizontalContentAlignment="Left"
                                    Content="Turn"
                                    Foreground="LightGray" />
                            </Grid>
                        </GroupBox>
                        <GroupBox
                            Margin="10,0,10,10"
                            BorderThickness="0"
                            Header="Test end action">
                            <Grid Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>

                                <CheckBox
                                    x:Name="cbSaveFailPCB"
                                    Grid.Row="0"
                                    Margin="0,2,2,0"
                                    Content="Save fail PCB test data" />
                                <CheckBox
                                    x:Name="cbUsePreEndSig"
                                    Grid.Row="1"
                                    Margin="0,2,2,0"
                                    Content="Use the pre-end signal" />
                            </Grid>
                        </GroupBox>
                        <GroupBox
                            Margin="10,0,10,10"
                            BorderThickness="0"
                            Header="Retry setting">
                            <Grid Margin="5">
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="0.3*" />
                                </Grid.ColumnDefinitions>

                                <Label Content="Retry count" Foreground="LightGray" />
                                <xc:IntegerUpDown
                                    x:Name="nudRetryCount"
                                    Grid.Column="1"
                                    Width="80"
                                    Margin="2"
                                    HorizontalAlignment="Right"
                                    Maximum="10"
                                    Minimum="0"
                                    Value="0" />
                                <Label
                                    Grid.Column="2"
                                    Content="EA"
                                    Foreground="LightGray" />

                                <CheckBox
                                    x:Name="cbSkipPass"
                                    Grid.Row="1"
                                    Margin="0,2,2,0"
                                    Content="Use the skip, test result pass PCB " />
                                <CheckBox
                                    x:Name="cbRetryUpdown"
                                    Grid.Row="2"
                                    Margin="0,2,2,0"
                                    VerticalAlignment="Center"
                                    Content="Use retry press updown" />
                                <xc:IntegerUpDown
                                    x:Name="nudRetryUpdown"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Width="80"
                                    Margin="2"
                                    HorizontalAlignment="Right"
                                    Maximum="10000"
                                    Minimum="0"
                                    Value="0" />
                                <Label
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Content="ms"
                                    Foreground="LightGray" />
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem
                Width="200"
                Height="40"
                Padding="0"
                Header="Comunication"
                Style="{StaticResource FlatTabControlLeft}">
                <Grid
                    Width="500"
                    Margin="-2,0,0,0"
                    HorizontalAlignment="Left"
                    Background="#003a71">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Grid
                        Height="Auto"
                        Margin="10"
                        VerticalAlignment="Top">
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition Width="0.7*" />
                            <ColumnDefinition Width="0.5*" />
                            <ColumnDefinition Width="0.6*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Label
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Right"
                            Content="System IO Port"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="1"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Right"
                            Content="LEVEL"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="2"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Right"
                            Content="MUX"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Content="#1"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="3"
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Content="#2"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="4"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Right"
                            Content="RELAY"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="5"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Right"
                            Content="SOLENOID"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="6"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Right"
                            Content="DMM"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="6"
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Content="#1"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="7"
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Content="#2"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="8"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Right"
                            Content="UUT"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="8"
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Content="#1"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="9"
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Content="#2"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="10"
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Content="#3"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="11"
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            Content="#4"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="12"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Right"
                            Content="Barcode"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="13"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Right"
                            Content="QR Printer"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="14"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Right"
                            Content="Power metter"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="15"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Right"
                            Content="Extension board"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="16"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Right"
                            Content="Microphone"
                            Foreground="LightGray" />
                        <Label
                            Grid.Row="17"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Right"
                            Content="Camera"
                            Foreground="LightGray" />

                        <ComboBox
                            x:Name="cbbSysPort"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />
                        <ComboBox
                            x:Name="cbbLevelPort"
                            Grid.Row="1"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />
                        <ComboBox
                            x:Name="cbbMux1Port"
                            Grid.Row="2"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />
                        <ComboBox
                            x:Name="cbbMux2Port"
                            Grid.Row="3"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />
                        <ComboBox
                            x:Name="cbbRelayPort"
                            Grid.Row="4"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />
                        <ComboBox
                            x:Name="cbbSolenoidPort"
                            Grid.Row="5"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />
                        <ComboBox
                            x:Name="cbbDMM1Port"
                            Grid.Row="6"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />
                        <ComboBox
                            x:Name="cbbDMM2Port"
                            Grid.Row="7"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />
                        <ComboBox
                            x:Name="cbbUUT1Port"
                            Grid.Row="8"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />
                        <ComboBox
                            x:Name="cbbUUT2Port"
                            Grid.Row="9"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />
                        <ComboBox
                            x:Name="cbbUUT3Port"
                            Grid.Row="10"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />
                        <ComboBox
                            x:Name="cbbUUT4Port"
                            Grid.Row="11"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />

                        <ComboBox
                            x:Name="cbbBarcodePort"
                            Grid.Row="12"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />
                        <ComboBox
                            x:Name="cbbBarcodeBaud"
                            Grid.Row="12"
                            Grid.Column="3"
                            Height="25"
                            Margin="5,2,5,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                            SelectedIndex="0">
                            <ComboBoxItem Content="9600" />
                            <ComboBoxItem Content="19200" />
                            <ComboBoxItem Content="38400" />
                            <ComboBoxItem Content="57600" />
                            <ComboBoxItem Content="115200" />
                        </ComboBox>
                        <ComboBox
                            x:Name="cbbBarcodeDatabit"
                            Grid.Row="12"
                            Grid.Column="4"
                            Height="25"
                            Margin="0,2,5,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                            SelectedIndex="1">
                            <ComboBoxItem Content="7" />
                            <ComboBoxItem Content="8" />
                        </ComboBox>

                        <ComboBox
                            x:Name="cbbBarcodeParity"
                            Grid.Row="12"
                            Grid.Column="5"
                            Height="25"
                            Margin="0,2,5,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />

                        <ComboBox
                            x:Name="cbbPrinterPort"
                            Grid.Row="13"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />
                        <ComboBox
                            x:Name="cbbPowerMetterPort"
                            Grid.Row="14"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />
                        <ComboBox
                            x:Name="cbbExtensionBoardPort"
                            Grid.Row="15"
                            Grid.Column="2"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center" />
                        <ComboBox
                            x:Name="cbbMicrophone"
                            Grid.Row="16"
                            Grid.Column="2"
                            Grid.ColumnSpan="4"
                            Height="25"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                            ToolTip="WASAPI capture endpoint for Sound Processing"
                            DisplayMemberPath="Name"/>
                        <Label
                            Grid.Row="17"
                            Grid.Column="2"
                            Grid.ColumnSpan="4"
                            Margin="0,2,0,2"
                            VerticalAlignment="Center"
                            Content="(DirectShow default)"
                            Foreground="#B0BEC5"
                            FontStyle="Italic"
                            ToolTip="Camera is auto-detected via OpenCvSharp DirectShow"/>

                        <!-- "Use" checkboxes: if unticked, the port skips the duplicate check + is not shown on the status bar -->
                        <CheckBox x:Name="chkSysPortUse"       Grid.Row="0"  Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkLevelUse"         Grid.Row="1"  Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkMux1Use"          Grid.Row="2"  Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkMux2Use"          Grid.Row="3"  Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkRelayUse"         Grid.Row="4"  Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkSolenoidUse"      Grid.Row="5"  Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkDMM1Use"          Grid.Row="6"  Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkDMM2Use"          Grid.Row="7"  Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkUUT1Use"          Grid.Row="8"  Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkUUT2Use"          Grid.Row="9"  Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkUUT3Use"          Grid.Row="10" Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkUUT4Use"          Grid.Row="11" Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkBarcodeUse"       Grid.Row="12" Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkPrinterUse"       Grid.Row="13" Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkPowerMetterUse"   Grid.Row="14" Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkExtensionBoardUse" Grid.Row="15" Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkMicrophoneUse"     Grid.Row="16" Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                        <CheckBox x:Name="chkCameraUse"         Grid.Row="17" Grid.Column="6" Margin="8,0,8,0" VerticalAlignment="Center" Foreground="LightGray" Content="Use" IsChecked="True"/>
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="50" />
                        </Grid.RowDefinitions>

                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

                            <StackPanel Orientation="Vertical">
                                <Label
                                    HorizontalAlignment="Center"
                                    Content=" Current Excel File Directory"
                                    Foreground="LightGray" />
                                <TextBox
                                    x:Name="txtBoxExcelFileDir"
                                    Margin="0,15,0,0"
                                    HorizontalAlignment="Center"
                                    Background="#003a71"
                                    BorderBrush="LightGray"
                                    BorderThickness="1"
                                    Foreground="LightGray"
                                    IsReadOnly="True" />
                                <CheckBox
                                    x:Name="cbExportLog"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Center"
                                    Content="Export log"
                                    Foreground="LightGray"
                                    IsChecked="True"
                                    ToolTip="Write the test result file into the directory above. Untick to run without exporting." />
                            </StackPanel>

                            <StackPanel Orientation="Vertical">
                                <Label Content="Change Excel File Directory" Foreground="LightGray" />
                                <Button
                                    x:Name="btnChangeExcelDir"
                                    Width="30"
                                    Height="26"
                                    Padding="0"
                                    HorizontalAlignment="Left"
                                    Background="#01000000"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Change Excel file directory"
                                    Click="btnChangeExcelDir_Click">
                                    <fa:IconBlock Icon="FolderOpen" FontSize="16" Foreground="#FFC107" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem
                Width="200"
                Height="40"
                Padding="0"
                Header="ETC Setting"
                Style="{StaticResource FlatTabControlLeft}">
                <Grid
                    Width="600"
                    Margin="-2,0,0,0"
                    HorizontalAlignment="Left"
                    Background="#003a71">
                    <StackPanel Margin="10">
                        <GroupBox BorderThickness="0" Header="Delay Setting">
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.6*" />
                                    <ColumnDefinition />
